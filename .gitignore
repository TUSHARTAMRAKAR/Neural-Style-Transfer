# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/

# ── Virtual environments ───────────────────────
venv/
env/
.env
.venv

# ── Environment variables ──────────────────────
.env
.env.local
.env.production

# ── Uploads & outputs (generated at runtime) ──
backend/uploads/
backend/outputs/
!backend/uploads/.gitkeep
!backend/outputs/.gitkeep

